{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/build",
  "installCommand": "npm install && cd server && npm install --omit=dev && cd ../client && npm install",
  "framework": null,
  "functions": {
    "api/agency/migration/import/**": {
      "maxDuration": 120
    },
    "api/agency/migration/reset.js": {
      "maxDuration": 120
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api|static|_next|favicon.ico|manifest.json|robots.txt).*)", "destination": "/index.html" }
  ]
}
